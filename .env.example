# 开发时 Prisma 会自动在连接串追加 pgbouncer=true，避免改列类型后出现
# "cached plan must not change result type"。若要关闭：PRISMA_PGBOUNCER=0
# 生产用 PgBouncer 事务池时仍应在 URL 带 pgbouncer=true，或设 PRISMA_PGBOUNCER=1。
DATABASE_URL="postgresql://user:password@localhost:5432/mech_commander?schema=public"
# PRISMA_PGBOUNCER=0
SESSION_SECRET="your-session-secret-at-least-32-characters-long"

# 驾驶指南手写识别（OpenAI 兼容 /chat/completions，需支持 image_url）
# DRIVING_GUIDE_VISION_API_KEY="sk-..."
# DRIVING_GUIDE_VISION_BASE_URL="https://api.openai.com/v1"
# DRIVING_GUIDE_VISION_MODEL="gpt-4o-mini"
# 也可用 OPENAI_API_KEY / OPENAI_BASE_URL；本地跳过识别：DRIVING_GUIDE_OCR_SKIP=1
# 若兼容接口不支持 response_format=json_object：DRIVING_GUIDE_VISION_NO_JSON_MODE=1

# 学生「机甲对话」：OpenAI 兼容 chat/completions + audio/transcriptions（Whisper）
# 可单独设置 MECHA_CHAT_*，否则复用 OPENAI_API_KEY / OPENAI_BASE_URL
# MECHA_CHAT_MODEL="gpt-4o-mini"
# MECHA_CHAT_TRANSCRIBE_MODEL="whisper-1"
# 若 OPENAI_BASE_URL 为仅转发 chat 的网关，语音转写会 404，需单独指向带 Whisper 的 API，例如：
# MECHA_CHAT_TRANSCRIBE_BASE_URL="https://api.openai.com/v1"
# MECHA_CHAT_TRANSCRIBE_API_KEY="sk-..."  # 可选，不设则与上面共用 Key
