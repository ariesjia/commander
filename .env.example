# 开发时 Prisma 会自动在连接串追加 pgbouncer=true，避免改列类型后出现
# "cached plan must not change result type"。若要关闭：PRISMA_PGBOUNCER=0
# 生产用 PgBouncer 事务池时仍应在 URL 带 pgbouncer=true，或设 PRISMA_PGBOUNCER=1。
DATABASE_URL="postgresql://user:password@localhost:5432/mech_commander?schema=public"
# PRISMA_PGBOUNCER=0
SESSION_SECRET="your-session-secret-at-least-32-characters-long"
