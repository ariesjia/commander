generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Parent {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  pinHash      String
  showPinyin   Boolean  @default(false) // 学生端是否显示拼音注音
  baseScore    Float    @default(1)    // 基准分：0.1 | 1 | 10，所有积分以1分为单位存储
  createdAt    DateTime @default(now())

  student Student?
  tasks  Task[]
  rewards Reward[]
}

model Student {
  id               String    @id @default(cuid())
  nickname         String
  totalPoints      Int       @default(0)
  balance          Int       @default(0)
  frozenPoints     Int       @default(0)
  streakDays       Int       @default(0)
  primaryMechaId   String?   @unique // 当前主机甲实例，首页展示、任务积分归属
  primaryMecha     StudentMecha? @relation("StudentPrimaryMecha", fields: [primaryMechaId], references: [id], onDelete: SetNull)
  lastActiveAt     DateTime?
  createdAt        DateTime  @default(now())

  parentId   String   @unique
  parent     Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  taskLogs   TaskLog[]
  exchanges  Exchange[]
  pointsLogs PointsLog[]
  studentMechas StudentMecha[]
  studentBattleLogs StudentBattleLog[]
}

// 学生领养的机甲及积分：积分仅来自领养后完成的任务，兑换奖励不扣
model StudentMecha {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mechaSlug String
  adoptedAt DateTime @default(now())
  points    Int      @default(0) // 领养后获得的任务积分，用于机甲升级

  taskLogs     TaskLog[]
  asPrimaryFor Student? @relation("StudentPrimaryMecha")

  @@unique([studentId, mechaSlug])
  @@index([studentId])
}

model Task {
  id            String    @id @default(cuid())
  name          String
  description   String?
  type          TaskType
  maxPoints     Int       @default(10) // 最大得分，完成时家长可给予 0～maxPoints
  penaltyPoints Int       @default(0) // 惩罚扣分（仅 RULE 类型使用）
  isActive      Boolean   @default(true)
  deletedAt     DateTime? // 软删除：删除后仍保留 TaskLog，支持撤销积分
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  parentId  String
  parent    Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  taskLogs  TaskLog[]
}

enum TaskType {
  DAILY
  WEEKLY
  RULE   // 规则：可奖励加分，可惩罚扣分
}

model Reward {
  id          String    @id @default(cuid())
  name        String
  description String?
  imageUrl    String?   // 奖励图片链接，支持任意可访问的图片 URL
  points      Int
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parentId   String
  parent     Parent     @relation(fields: [parentId], references: [id], onDelete: Cascade)
  exchanges  Exchange[]
}

enum ExchangeStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED  // 学生自己取消
}

model Exchange {
  id          String          @id @default(cuid())
  status      ExchangeStatus  @default(PENDING)
  pointsCost  Int
  rejectReason String?
  createdAt   DateTime        @default(now())
  confirmedAt DateTime?

  rewardId   String
  reward     Reward  @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model PointsLog {
  id          String         @id @default(cuid())
  amount      Int
  type        PointsLogType
  description String
  createdAt   DateTime       @default(now())

  studentId   String
  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  taskLogId   String?
  taskLog     TaskLog? @relation(fields: [taskLogId], references: [id], onDelete: SetNull)
  studentBattleLog StudentBattleLog?

  @@index([studentId])
}

/// 学生每日战斗记录（每自然日最多一条，与 Asia/Shanghai 日历日对齐）
model StudentBattleLog {
  id          String        @id @default(cuid())
  studentId   String
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  foughtOn    DateTime      @db.Date
  outcome     BattleOutcome
  enemyId     String
  narrative   String
  rewardsJson Json?
  pointsLogId String?       @unique
  pointsLog   PointsLog?    @relation(fields: [pointsLogId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())

  @@unique([studentId, foughtOn])
  @@index([studentId])
}

enum BattleOutcome {
  WIN
  LOSE
}

model TaskLog {
  id             String   @id @default(cuid())
  completedAt    DateTime @default(now())
  pointsAwarded Int
  studentMechaId String?  // 确认时获得积分的机甲实例，撤销时用于回滚（支持同款机甲重复领养）

  taskId   String
  task     Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  studentId String
  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentMecha StudentMecha? @relation(fields: [studentMechaId], references: [id], onDelete: SetNull)
  pointsLogs PointsLog[]

  @@index([taskId, studentId])
  @@index([studentMechaId])
}

// 机甲配置：由后端提供，支持后续扩展
model Mecha {
  id          String   @id @default(cuid())
  slug        String   @unique // 唯一标识，如 xuanjia
  name        String
  description String?
  intro       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  levels MechaLevel[]
}

model MechaLevel {
  id          String   @id @default(cuid())
  mechaId     String
  mecha       Mecha    @relation(fields: [mechaId], references: [id], onDelete: Cascade)
  level       Int
  name        String
  threshold   Int
  imageUrl    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([mechaId, level])
  @@index([mechaId])
}

enum PointsLogType {
  TASK_REWARD
  TASK_REWARD_UNDO
  TASK_PENALTY
  TASK_PENALTY_UNDO
  EXCHANGE_COST
  EXCHANGE_REFUND
  BATTLE_REWARD
}
