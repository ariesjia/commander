generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Parent {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  pinHash      String
  showPinyin   Boolean  @default(false) // 学生端是否显示拼音注音
  baseScore    Float    @default(1)    // 基准分：0.1 | 1 | 10，所有积分以1分为单位存储
  /// 学生端「机甲维修」口算小游戏，默认开启
  maintenanceMathEnabled Boolean @default(true)
  /// 每日战斗：当日 TASK_REWARD 累计需达到该值（0–10，家长设置；0 表示不门槛）
  dailyBattleMinTaskPoints Int @default(5)
  createdAt    DateTime @default(now())

  student Student?
  tasks  Task[]
  rewards Reward[]
}

model Student {
  id               String    @id @default(cuid())
  nickname         String
  totalPoints      Decimal   @default(0) @db.Decimal(16, 8)
  balance          Decimal   @default(0) @db.Decimal(16, 8)
  frozenPoints     Decimal   @default(0) @db.Decimal(16, 8)
  streakDays       Int       @default(0)
  primaryMechaId   String?   @unique // 当前主机甲实例，首页展示、任务积分归属
  primaryMecha     StudentMecha? @relation("StudentPrimaryMecha", fields: [primaryMechaId], references: [id], onDelete: SetNull)
  lastActiveAt     DateTime?
  createdAt        DateTime  @default(now())

  parentId   String   @unique
  parent     Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  taskLogs   TaskLog[]
  exchanges  Exchange[]
  pointsLogs PointsLog[]
  studentMechas StudentMecha[]
  studentBattleLogs StudentBattleLog[]
  studentItems    StudentItem[]
  studentMaintenanceMathLogs StudentMaintenanceMathLog[]
}

/// 每日机甲维修（口算）完成记录，无积分
model StudentMaintenanceMathLog {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  completedOn  DateTime @db.Date // 中国时区自然日
  completedAt  DateTime @default(now())
  correctCount Int
  totalCount   Int
  /// 维修用时（毫秒），由学生端从开始检修起计时提交
  durationMs   Int      @default(0)
  generatorId  String
  sessionHash  String?
  /// 维修完成额外掉落（约 50% 概率抽一件活跃道具）
  bonusItemId String?
  bonusItem   Item?    @relation(fields: [bonusItemId], references: [id], onDelete: SetNull)

  @@unique([studentId, completedOn])
  @@index([studentId])
}

enum ItemKind {
  DISPLAY // 展示/纪念
  MATERIAL // 材料（预留：盲盒碎片等）
  CONSUMABLE // 消耗品（预留：盲盒等）
}

/// 全局道具定义（名称、介绍、图片）
model Item {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @db.Text
  imageUrl    String
  kind        ItemKind @default(DISPLAY)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studentItems StudentItem[]
  maintenanceMathBonusDrops StudentMaintenanceMathLog[]
}

/// 学生持有数量（堆叠）
model StudentItem {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  quantity  Int      @default(0)

  @@unique([studentId, itemId])
  @@index([studentId])
}

// 学生领养的机甲及积分：积分仅来自领养后完成的任务，兑换奖励不扣
model StudentMecha {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mechaSlug String
  adoptedAt DateTime @default(now())
  points    Decimal  @default(0) @db.Decimal(16, 8) // 领养后获得的任务积分，用于机甲升级

  taskLogs     TaskLog[]
  asPrimaryFor Student? @relation("StudentPrimaryMecha")

  @@unique([studentId, mechaSlug])
  @@index([studentId])
}

model Task {
  id            String    @id @default(cuid())
  name          String
  description   String?
  type          TaskType
  maxPoints     Decimal   @default(10) @db.Decimal(16, 8) // 最大得分，完成时家长可给予 0～maxPoints
  penaltyPoints Decimal   @default(0) @db.Decimal(16, 8) // 惩罚扣分（仅 RULE 类型使用）
  isActive      Boolean   @default(true)
  deletedAt     DateTime? // 软删除：删除后仍保留 TaskLog，支持撤销积分
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  parentId  String
  parent    Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  taskLogs  TaskLog[]
}

enum TaskType {
  DAILY
  WEEKLY
  RULE   // 规则：可奖励加分，可惩罚扣分
}

model Reward {
  id          String    @id @default(cuid())
  name        String
  description String?
  imageUrl    String?   // 奖励图片链接，支持任意可访问的图片 URL
  points      Decimal   @db.Decimal(16, 8)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parentId   String
  parent     Parent     @relation(fields: [parentId], references: [id], onDelete: Cascade)
  exchanges  Exchange[]
}

enum ExchangeStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED  // 学生自己取消
}

model Exchange {
  id          String          @id @default(cuid())
  status      ExchangeStatus  @default(PENDING)
  pointsCost  Decimal         @db.Decimal(16, 8)
  rejectReason String?
  createdAt   DateTime        @default(now())
  confirmedAt DateTime?

  rewardId   String
  reward     Reward  @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model PointsLog {
  id          String         @id @default(cuid())
  amount      Decimal        @db.Decimal(16, 8)
  type        PointsLogType
  description String
  createdAt   DateTime       @default(now())

  studentId   String
  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  taskLogId   String?
  taskLog     TaskLog? @relation(fields: [taskLogId], references: [id], onDelete: SetNull)
  studentBattleLog StudentBattleLog?

  @@index([studentId])
}

/// 学生每日战斗记录（每自然日最多一条，与 Asia/Shanghai 日历日对齐）
model StudentBattleLog {
  id          String        @id @default(cuid())
  studentId   String
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mechaId     String?
  mecha       Mecha?        @relation(fields: [mechaId], references: [id], onDelete: SetNull)
  foughtOn    DateTime      @db.Date
  outcome     BattleOutcome
  enemyId     String
  narrative   String
  rewardsJson Json?
  /** 演出步骤快照 ServerBattleStep[]，供回放与 POST 一致 */
  stepsJson   Json?
  pointsLogId String?       @unique
  pointsLog   PointsLog?    @relation(fields: [pointsLogId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())

  @@unique([studentId, foughtOn])
  @@index([studentId])
  @@index([mechaId])
}

enum BattleOutcome {
  WIN
  LOSE
}

model TaskLog {
  id             String   @id @default(cuid())
  completedAt    DateTime @default(now())
  pointsAwarded  Decimal  @db.Decimal(16, 8)
  studentMechaId String?  // 确认时获得积分的机甲实例，撤销时用于回滚（支持同款机甲重复领养）

  taskId   String
  task     Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  studentId String
  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentMecha StudentMecha? @relation(fields: [studentMechaId], references: [id], onDelete: SetNull)
  pointsLogs PointsLog[]

  @@index([taskId, studentId])
  @@index([studentMechaId])
}

// 机甲配置：由后端提供，支持后续扩展
model Mecha {
  id          String   @id @default(cuid())
  slug        String   @unique // 唯一标识，如 xuanjia
  name        String
  description String?
  intro       String?
  /// 可选进化/展示视频（公开 URL，如 /mecha/razor/animation.mp4）
  evolutionVideoUrl String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  levels            MechaLevel[]
  skills            MechaSkill[]
  studentBattleLogs StudentBattleLog[]
}

model MechaLevel {
  id          String   @id @default(cuid())
  mechaId     String
  mecha       Mecha    @relation(fields: [mechaId], references: [id], onDelete: Cascade)
  level       Int
  name        String
  threshold   Decimal  @db.Decimal(16, 8)
  imageUrl    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([mechaId, level])
  @@index([mechaId])
}

enum MechaSkillKind {
  ATTACK
  DEFENSE
  BUFF
  HEAL
  CONTROL
  SUPPORT
}

model MechaSkill {
  id          String         @id @default(cuid())
  mechaId     String
  mecha       Mecha          @relation(fields: [mechaId], references: [id], onDelete: Cascade)
  unlockLevel Int
  kind        MechaSkillKind
  slug        String
  name        String
  description String         @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([mechaId, unlockLevel])
  @@unique([mechaId, slug])
  @@index([mechaId])
  @@index([kind])
}

enum PointsLogType {
  TASK_REWARD
  TASK_REWARD_UNDO
  TASK_PENALTY
  TASK_PENALTY_UNDO
  EXCHANGE_COST
  EXCHANGE_REFUND
  BATTLE_REWARD
}
